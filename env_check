#!/bin/bash

#env_check.sh
#Tyler Spurrell
#Started June 2nd
#Finished June 3rd
#The purpose of this script will be to verify that the server meets the minimum requirements before any client setup occurs.

#Below are all the variables used in the script
log_dir="$HOME/onboarding"
log_file="$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
threshold_file="$HOME/disk_threshold.cfg"
min_space=500
availablemb=$(df -m --output=avail / | tail -n 1 )
#man df showed me the --output as I was unsure of the best way to display the output for 1.3
etc="/etc"
var="/var/log"
tmp="/tmp"


#if statement to verify that /var/log/onboarding exists, script will exit if it does not exist.
    if [ -d $log_dir ]
    then
    echo "The log directory exists." >> "$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
    echo "The log directory exists."
    else 
    echo "Log directory $log_dir does not exist. Cannot proceed, please create $log_dir." >> "$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
    echo "Log directory $log_dir does not exist. Cannot proceed, please create $log_dir"
    exit
fi

#if statement to verify that a minimum of 500MB of disk space is free, script will exit if there isn't enough space.
if [ "$availablemb" -ge "$min_space" ]
    then
    echo "[OK]: Disk space check passed." >> "$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
    echo "Available: $availablemb MB | Required: $min_space MB" >> "$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
    echo "[OK]: Disk space check passed."
    echo "Available: $availablemb MB | Required: $min_space MB"
    else
    echo "[FAILED]: Disk space check failed, please ensure you have a minimum of 500MB free" >> "$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
    echo "[FAILED]: Disk space check failed, please ensure you have a minimum of 500MB free"
    exit
fi

#The following 3 if statements will check to see if /etc, /var/log, and /tmp exist.
if [ -d $etc ]
    then
    echo "$etc exists." >> "$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
    echo "$etc exists."
    else
    echo "$etc does not exist." >> "$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
    echo "$etc does not exist."
fi

if [ -d $var ]
    then
    echo "$var exists." >> "$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
    echo "$var exists."
    else
    echo "$var does not exist." >> "$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
    echo "$var does not exist."
fi

if [ -d $tmp ]
    then
    echo "$tmp exists." >> "$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
    echo "$tmp exists."
    else
    echo "$tmp does not exist." >> "$HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
    echo "$tmp does not exist."
fi

echo "Environment Check Completed.
Log saved to: $HOME/onboarding/onboarding_logs/env_check_$(date +%F).log"
